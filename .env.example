# X / Twitter API
X_BEARER_TOKEN=your_bearer_token
X_CONSUMER_KEY=your_consumer_key
X_CONSUMER_SECRET=your_consumer_secret
X_ACCESS_TOKEN=your_access_token
X_ACCESS_TOKEN_SECRET=your_access_token_secret

# Gemini (for thread + tweet generation)
GEMINI_API_KEY=your_gemini_api_key

# GitHub (optional — increases rate limit from 60 to 5000 req/hr)
GITHUB_TOKEN=your_github_personal_access_token

# Telegram (for notifications)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Behaviour
DRY_RUN=true       # set to false when ready to post live
LOG_LEVEL=INFO

# Newsletter (optional)
BEEHIIV_API_KEY=   # leave blank to skip newsletter posting (drafts still saved locally)
BEEHIIV_PUB_ID=    # your Beehiiv publication ID
